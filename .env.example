# Sekmen Zemin Tasarım — Üretim/Geliştirme .env şablonu
# Deploy Anayasası (04) kurallarına göre doldurun. .env asla Git'e gönderilmez.

APP_NAME="Sekmen Zemin Tasarım"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://www.sekmenzemintasarim.com

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# --- Veritabanı (Anayasa §2/§14) ---
# DB_HOST kesinlikle localhost. cPanel prefix'i (kullaniciadi_) dahil, 16 karakter
# kuralına göre TAM görünen adı yazın. Şifrede $ " \ KULLANMAYIN (§15).
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=kullaniciadi_sekmen
DB_USERNAME=kullaniciadi_sekmen
DB_PASSWORD='guvenli_sifre_2026!'

# --- İlk kurulumda DB değil FILE (Anayasa §2.3 — döngü engelleme) ---
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public

# --- E-posta (cPanel SMTP) ---
MAIL_MAILER=smtp
MAIL_HOST=mail.sekmenzemintasarim.com
MAIL_PORT=465
MAIL_USERNAME=info@sekmenzemintasarim.com
MAIL_PASSWORD=
MAIL_SCHEME=smtps
MAIL_FROM_ADDRESS="info@sekmenzemintasarim.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_LEAD_NOTIFY="info@sekmenzemintasarim.com"

# Sistem bakım secret route'u (Anayasa §5) — TAHMİN EDİLEMEZ bir değer girin
SYSTEM_SECRET=degistirin-uzun-rastgele-deger
